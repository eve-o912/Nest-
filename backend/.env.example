# Database
DATABASE_URL=postgresql://nest_user:nest_password@localhost:5432/nest_db

# JWT
JWT_SECRET=your_64_character_random_string_here_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Africa's Talking (OTP & SMS)
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=sandbox_or_your_username
AT_SENDER=NEST

# Safaricom Daraja (M-Pesa)
DARAJA_CONSUMER_KEY=your_daraja_consumer_key
DARAJA_CONSUMER_SECRET=your_daraja_consumer_secret
DARAJA_PASSKEY=your_mpesa_passkey
DARAJA_SHORTCODE=your_till_or_paybill_number
DARAJA_CALLBACK_URL=https://api.nest.app/webhooks/daraja

# Stitch/Mono (Bank Feeds)
STITCH_CLIENT_ID=your_stitch_client_id
STITCH_CLIENT_SECRET=your_stitch_client_secret
MONO_API_KEY=your_mono_api_key

# Claude API (AI Insights)
CLAUDE_API_KEY=your_anthropic_api_key

# Cloudflare R2 (File Storage)
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET=nest-receipts

# Upstash Redis (Rate Limiting & Sessions)
REDIS_URL=rediss://your_upstash_token@your_upstash_host:6379

# Blockchain (Future)
CELO_PRIVATE_KEY=your_celo_wallet_private_key
CELO_RPC_URL=https://forno.celo.org

# Encryption
ENCRYPTION_KEY=your_32_byte_aes_key_for_encryption

# Environment
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
WEB_URL=https://app.nest.app
RECEIPT_WEB_URL=https://receipt.nest.app

# WebSocket
WS_PORT=3001
